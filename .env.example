# Flask session signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=dev-secret-key-change-in-production

# Yahoo Developer App credentials (https://developer.yahoo.com/apps/)
YAHOO_CLIENT_ID=your_consumer_key_here
YAHOO_CLIENT_SECRET=your_consumer_secret_here

# OAuth callback URL (must match Yahoo app's Redirect URI)
YAHOO_REDIRECT_URI=http://localhost:8080/auth/yahoo/callback

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# If not set, derived from SECRET_KEY automatically (fine for dev, set explicitly in production)
# TOKEN_ENCRYPTION_KEY=
